<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <RootNamespace>PhoenixmlDb.XQuery.Cli</RootNamespace>
    <AssemblyName>xquery</AssemblyName>
    <Description>Command-line XQuery processor for XML files, directories, and URLs</Description>
    <Authors>endpointsystems</Authors>
    <!-- dotnet tool support -->
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>xquery</ToolCommandName>
    <PackageId>PhoenixmlDb.XQuery.Cli</PackageId>
    <!-- CLI tools: suppress localization, case normalization, and ConfigureAwait warnings -->
    <NoWarn>$(NoWarn);CA1303;CA1308;CA2000;CA2007</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="PhoenixmlDb.XQuery" />
  </ItemGroup>

</Project>
